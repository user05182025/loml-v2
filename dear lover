<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Happy Anniversary 💙</title>

<style>
*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:'Poppins',sans-serif;
}

body{
background:#8fb6d9;
height:100vh;
overflow:hidden;
display:flex;
justify-content:center;
align-items:center;
}

/* LOGIN PAGE */

.login-page{
position:absolute;
width:100%;
height:100%;
display:flex;
justify-content:center;
align-items:center;
background:#8fb6d9;
transition:1s;
z-index:5;
}

.login-box{
background:rgba(255,255,255,0.15);
backdrop-filter:blur(10px);
padding:40px 30px;
border-radius:25px;
text-align:center;
width:320px;
box-shadow:0 10px 30px rgba(0,0,0,0.15);
animation:fadeIn 1s ease;
}

.login-box h1{
color:white;
font-size:28px;
margin-bottom:15px;
}

.login-box p{
color:white;
font-size:14px;
margin-bottom:20px;
}

input{
width:100%;
padding:14px;
border:none;
border-radius:15px;
outline:none;
margin-bottom:20px;
font-size:16px;
text-align:center;
}

button{
padding:12px 25px;
border:none;
border-radius:20px;
background:white;
color:#5d8bb3;
font-weight:bold;
font-size:15px;
cursor:pointer;
transition:0.3s;
}

button:hover{
transform:scale(1.05);
}

/* LETTER PAGE */

.letter-page{
display:none;
width:100%;
height:100%;
justify-content:center;
align-items:center;
position:absolute;
background:#8fb6d9;
overflow:hidden;
}

.envelope{
position:relative;
width:320px;
height:220px;
background:#ffffff;
border-radius:10px;
box-shadow:0 15px 40px rgba(0,0,0,0.2);
overflow:hidden;
}

.envelope:before{
content:'';
position:absolute;
top:0;
left:0;
width:100%;
height:100%;
background:#dfefff;
clip-path:polygon(0 0,50% 50%,100% 0);
z-index:3;
}

.letter{
position:absolute;
width:90%;
height:280px;
background:white;
left:5%;
top:25px;
border-radius:10px;
padding:25px;
z-index:2;
animation:slideUp 2s ease forwards;
overflow:auto;
}

.letter h2{
text-align:center;
margin-bottom:20px;
color:#5d8bb3;
}

.letter p{
color:#444;
line-height:1.7;
font-size:15px;
white-space:pre-line;
}

@keyframes slideUp{
0%{
transform:translateY(180px);
}
100%{
transform:translateY(-70px);
}
}

@keyframes fadeIn{
from{
opacity:0;
transform:translateY(20px);
}
to{
opacity:1;
transform:translateY(0);
}
}

.hearts{
position:absolute;
width:100%;
height:100%;
overflow:hidden;
pointer-events:none;
}

.hearts span{
position:absolute;
bottom:-50px;
font-size:20px;
animation:float 8s linear infinite;
color:white;
opacity:0.7;
}

@keyframes float{
0%{
transform:translateY(0) rotate(0deg);
opacity:0;
}
30%{
opacity:1;
}
100%{
transform:translateY(-1000px) rotate(360deg);
opacity:0;
}
}

.hearts span:nth-child(1){left:10%;animation-delay:0s;}
.hearts span:nth-child(2){left:30%;animation-delay:2s;}
.hearts span:nth-child(3){left:50%;animation-delay:4s;}
.hearts span:nth-child(4){left:70%;animation-delay:1s;}
.hearts span:nth-child(5){left:90%;animation-delay:3s;}

</style>
</head>

<body>

<div class="login-page" id="loginPage">

<div class="login-box">
<h1>Happy Anniversary Lover 💙</h1>
<p>clue: anniversary date</p>

<input type="password" id="password" placeholder="Enter password">

<button onclick="openLetter()">Open Letter</button>
</div>

</div>

<div class="letter-page" id="letterPage">

<div class="hearts">
<span>♡</span>
<span>♡</span>
<span>♡</span>
<span>♡</span>
<span>♡</span>
</div>

<div class="envelope">

<div class="letter">

<h2>My Love 💙</h2>

<p>
WRITE YOUR MESSAGE HERE
</p>

</div>

</div>

</div>

<script>

function openLetter(){

const password = document.getElementById("password").value;

if(password === "YOURANNIVERSARYDATE"){

document.getElementById("loginPage").style.display = "none";
document.getElementById("letterPage").style.display = "flex";

}else{
alert("Wrong anniversary date 💔");
}

}

</script>

</body>
</html>
