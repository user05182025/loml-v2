<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Happy Anniversary Lover 💙</title>

  <style>
    *{
      margin:0;
      padding:0;
      box-sizing:border-box;
      font-family: 'Poppins', sans-serif;
    }

    body{
      background: linear-gradient(to bottom, #b7d7f7, #dcecff);
      height:100vh;
      overflow:hidden;
      display:flex;
      justify-content:center;
      align-items:center;
      color:#1d3557;
    }

    .container{
      width:100%;
      padding:20px;
      display:flex;
      justify-content:center;
      align-items:center;
    }

    /* LOGIN PAGE */

    .login-box{
      background: rgba(255,255,255,0.2);
      backdrop-filter: blur(12px);
      padding:35px 25px;
      border-radius:25px;
      width:100%;
      max-width:350px;
      text-align:center;
      box-shadow:0 8px 30px rgba(0,0,0,0.1);
      animation:fadeIn 1s ease;
    }

    .login-box h1{
      font-size:28px;
      margin-bottom:12px;
      color:#0d3b66;
    }

    .login-box p{
      margin-bottom:20px;
      color:#355070;
      font-size:15px;
    }

    input{
      width:100%;
      padding:14px;
      border:none;
      border-radius:15px;
      outline:none;
      margin-bottom:18px;
      font-size:16px;
      text-align:center;
      background:white;
    }

    button{
      background:#4ea8de;
      color:white;
      border:none;
      padding:14px 24px;
      border-radius:15px;
      font-size:16px;
      cursor:pointer;
      transition:0.3s;
    }

    button:hover{
      background:#219ebc;
      transform:scale(1.03);
    }

    /* LETTER PAGE */

    .letter-page{
      display:none;
      justify-content:center;
      align-items:center;
      flex-direction:column;
      width:100%;
      animation:fadeIn 1s ease;
    }

    .envelope{
      position:relative;
      width:320px;
      height:220px;
      background:#ffffff;
      border-radius:12px;
      box-shadow:0 10px 30px rgba(0,0,0,0.15);
      overflow:hidden;
    }

    .envelope::before{
      content:'';
      position:absolute;
      top:0;
      left:0;
      width:100%;
      height:100%;
      background:#d7ecff;
      clip-path:polygon(0 0, 50% 50%, 100% 0);
      z-index:2;
    }

    .letter{
      position:absolute;
      width:88%;
      height:230px;
      background:white;
      left:6%;
      top:100px;
      border-radius:10px;
      padding:25px;
      z-index:1;
      box-shadow:0 5px 15px rgba(0,0,0,0.1);
      animation:slideUp 2s ease forwards;
      overflow:auto;
    }

    .letter h2{
      text-align:center;
      margin-bottom:18px;
      color:#0d3b66;
    }

    .letter p{
      font-size:15px;
      line-height:1.8;
      color:#355070;
      white-space:pre-line;
    }

    @keyframes slideUp{
      0%{
        top:120px;
      }

      100%{
        top:-30px;
      }
    }

    @keyframes fadeIn{
      from{
        opacity:0;
        transform:translateY(10px);
      }

      to{
        opacity:1;
        transform:translateY(0);
      }
    }

    @media(max-width:480px){

      .envelope{
        width:290px;
        height:200px;
      }

      .letter{
        height:220px;
      }

    }

  </style>
</head>

<body>

  <div class="container">

    <!-- LOGIN PAGE -->

    <div class="login-box" id="loginPage">

      <h1>Happy Anniversary Lover 💙</h1>

      <p>Clue: our anniversary date</p>

      <input type="password" id="password" placeholder="Enter date here">

      <button onclick="openLetter()">
        Open Letter
      </button>

    </div>



    <!-- LETTER PAGE -->

    <div class="letter-page" id="letterPage">

      <div class="envelope">

        <div class="letter">

          <h2>Dear Lover, </h2>

          <p>

WRITE YOUR MESSAGE HERE

          </p>

        </div>

      </div>

    </div>

  </div>

  <script>

    function openLetter(){

      const password = document.getElementById("password").value;

      if(password === "05/18/2025"){

        document.getElementById("loginPage").style.display = "none";

        document.getElementById("letterPage").style.display = "flex";

      }

      else{

        alert("Wrong anniversary date 💔");

      }

    }

  </script>

</body>
</html>
